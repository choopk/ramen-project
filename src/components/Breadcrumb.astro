---
// Visible breadcrumb trail. Pair it with SchemaBreadcrumb (same `crumbs` array)
// so the on-page UI and the BreadcrumbList JSON-LD never drift. The last crumb is
// the current page: rendered as plain text with aria-current, not a link.
interface Crumb {
  name: string;
  href: string;
}

interface Props {
  crumbs: Crumb[];
  class?: string;
}

const { crumbs, class: className } = Astro.props;
---

<nav
  aria-label="Breadcrumb"
  class:list={['text-sm text-[color:var(--color-ink-soft)]', className]}
>
  <ol class="flex flex-wrap items-center gap-x-2 gap-y-1">
    {
      crumbs.map((crumb, i) => {
        const isLast = i === crumbs.length - 1;
        return (
          <li class="flex items-center gap-x-2">
            {isLast ? (
              <span aria-current="page" class="text-[color:var(--color-ink)]">
                {crumb.name}
              </span>
            ) : (
              <a
                href={crumb.href}
                class="rounded no-underline hover:text-[color:var(--color-ink)] hover:underline focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-[color:var(--color-accent)]"
              >
                {crumb.name}
              </a>
            )}
            {!isLast && (
              <span aria-hidden="true" class="text-[color:var(--color-rule)]">
                ・
              </span>
            )}
          </li>
        );
      })
    }
  </ol>
</nav>
