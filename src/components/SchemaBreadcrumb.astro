---
// BreadcrumbList JSON-LD. Driven by the same `crumbs` array as the visible
// Breadcrumb component so the structured data matches what users see and never
// points at a non-existent URL.
interface Crumb {
  name: string;
  href: string;
}

interface Props {
  crumbs: Crumb[];
}

const { crumbs } = Astro.props;

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: crumbs.map((crumb, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    name: crumb.name,
    item: new URL(crumb.href, Astro.site).toString(),
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(jsonLd)} is:inline />
