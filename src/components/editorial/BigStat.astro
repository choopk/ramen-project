---
// A single big-number card. Lives inside StatGrid (not a direct child of the prose shell,
// so it needs no cc-block spacing of its own).
interface Props {
  value: string;
  label: string;
  sub?: string;
  emphasis?: boolean;
}

const { value, label, sub, emphasis = false } = Astro.props;
---

<div class="rounded-lg border border-[color:var(--color-rule)] bg-[color:var(--color-paper-soft)] px-4 py-4">
  <div
    class="font-[family-name:var(--font-serif)] text-3xl font-semibold leading-none"
    style={emphasis ? 'color: var(--color-accent-ink);' : 'color: var(--color-ink);'}
  >
    {value}
  </div>
  <div class="mt-2 text-sm font-medium text-[color:var(--color-ink)]">{label}</div>
  {sub && <div class="mt-0.5 text-xs text-[color:var(--color-ink-soft)]">{sub}</div>}
</div>
