---
// Wraps a chart or <img> with an optional caption and source line. `width` opts into the
// reading-shell breakout (see .prose-shell in global.css): 'wide' and 'full' escape the prose
// column. `aspectRatio` reserves space for raw <img> children to keep CLS at zero (inline SVG
// charts already carry their own intrinsic ratio via viewBox, so they need no aspectRatio).
interface Props {
  caption?: string;
  source?: string;
  sourceHref?: string;
  width?: 'column' | 'wide' | 'full';
  aspectRatio?: string;
}

const { caption, source, sourceHref, width = 'column', aspectRatio } = Astro.props;
const breakout = width === 'wide' ? 'breakout-wide' : width === 'full' ? 'breakout-full' : '';
---

<figure class:list={['not-prose cc-block', breakout]}>
  <div
    class="rounded-lg border border-[color:var(--color-rule)] bg-[color:var(--color-paper-soft)] p-4 sm:p-6"
    style={aspectRatio ? `aspect-ratio: ${aspectRatio};` : undefined}
  >
    <slot />
  </div>
  {
    (caption || source) && (
      <figcaption class="mt-3 text-sm leading-relaxed text-[color:var(--color-ink-soft)]">
        {caption}
        {source && (
          <span class="mt-1 block text-xs text-[color:var(--color-ink-soft)]">
            Source: {sourceHref ? (
              <a href={sourceHref} class="underline">
                {source}
              </a>
            ) : (
              source
            )}
          </span>
        )}
      </figcaption>
    )
  }
</figure>
