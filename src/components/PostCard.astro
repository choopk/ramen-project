---
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
  // Featured renders the full-width hero card (paper-soft, vermillion crown, larger type);
  // default renders the grid card.
  featured?: boolean;
}

const { post, featured = false } = Astro.props;
const { title, description, pubDate, tags } = post.data;
const dateLabel = pubDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
const chipClass =
  'rounded-[2px] border border-[color:var(--color-accent)] px-1.5 py-0.5 text-[10px] uppercase tracking-wider text-[color:var(--color-accent-ink)]';
---

{
  featured ? (
    <article class="rounded-sm border border-t-2 border-[color:var(--color-rule)] border-t-[color:var(--color-accent)] bg-[color:var(--color-paper-soft)] p-7 sm:p-10">
      <a href={`/blog/${post.id}/`} class="group block no-underline">
        <p class="flex items-baseline gap-2 text-xs font-semibold uppercase tracking-[0.2em] text-[color:var(--color-ink)]">
          Featured
          <span lang="ja" aria-hidden="true" class="jp-accent text-[11px]">特集</span>
        </p>
        <h2 class="mt-4 font-[family-name:var(--font-serif)] text-3xl font-semibold leading-tight text-[color:var(--color-ink)] group-hover:text-[color:var(--color-accent-ink)] sm:text-4xl">
          {title}
        </h2>
        <p class="mt-4 max-w-2xl text-[15px] text-[color:var(--color-ink-soft)]">{description}</p>
        <div class="mt-5 flex flex-wrap items-center gap-x-3 gap-y-1.5 text-xs uppercase tracking-wider text-[color:var(--color-ink-soft)]">
          <time datetime={pubDate.toISOString()}>{dateLabel}</time>
          {tags.map((tag) => (
            <span class={chipClass}>{tag}</span>
          ))}
        </div>
      </a>
    </article>
  ) : (
    <article class="h-full rounded-sm border border-[color:var(--color-rule)] bg-[color:var(--color-paper)] p-5 transition-colors hover:border-[color:var(--color-accent)]">
      <a href={`/blog/${post.id}/`} class="group flex h-full flex-col no-underline">
        <h2 class="font-[family-name:var(--font-serif)] text-xl font-semibold leading-snug text-[color:var(--color-ink)] group-hover:text-[color:var(--color-accent-ink)]">
          {title}
        </h2>
        <p class="mt-2 text-sm text-[color:var(--color-ink-soft)]">{description}</p>
        <div class="mt-auto flex flex-wrap items-center gap-x-3 gap-y-1.5 pt-4 text-xs uppercase tracking-wider text-[color:var(--color-ink-soft)]">
          <time datetime={pubDate.toISOString()}>{dateLabel}</time>
          {tags.map((tag) => (
            <span class={chipClass}>{tag}</span>
          ))}
        </div>
      </a>
    </article>
  )
}
