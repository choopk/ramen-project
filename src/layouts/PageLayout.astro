---
import BaseHead from '../components/BaseHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import SchemaBreadcrumb from '../components/SchemaBreadcrumb.astro';
import { SITE } from '../consts';

interface Props {
  title: string;
  description: string;
  noindex?: boolean;
  // Optional "Last updated" date label, used by policy pages.
  lastUpdated?: string;
}

const { title, description, noindex = false, lastUpdated } = Astro.props;

const crumbs = [
  { name: 'Home', href: '/' },
  { name: title, href: Astro.url.pathname },
];
---

<!doctype html>
<html lang={SITE.locale}>
  <head>
    <BaseHead title={title} description={description} />
    {noindex && <meta name="robots" content="noindex" />}
    {!noindex && <SchemaBreadcrumb crumbs={crumbs} />}
  </head>
  <body>
    <Header />
    <main id="main" tabindex="-1" class="mx-auto max-w-3xl px-5 py-12 focus:outline-none">
      <Breadcrumb crumbs={crumbs} class="mb-6" />
      <header class="mb-10">
        <h1 class="font-[family-name:var(--font-serif)] text-4xl font-semibold leading-tight tracking-tight text-[color:var(--color-ink)] sm:text-5xl">
          {title}
        </h1>
        <p class="mt-4 text-lg text-[color:var(--color-ink-soft)]">{description}</p>
        {lastUpdated && (
          <p class="mt-4 text-xs uppercase tracking-wider text-[color:var(--color-ink-soft)]">
            Last updated {lastUpdated}
          </p>
        )}
        <span class="washi-rule mt-7" aria-hidden="true"></span>
      </header>
      <div class="prose prose-lg max-w-none">
        <slot />
      </div>
    </main>
    <Footer />
  </body>
</html>
