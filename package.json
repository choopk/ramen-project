{
  "name": "ramen-guide",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "format:astro": "echo 'oxfmt does not yet support .astro files (planned upstream). When it ships, drop this and add **/*.astro to the format scripts.' && exit 0",
    "check": "astro check",
    "audit": "node scripts/audit-approval.mjs",
    "audit:meta": "node scripts/audit-meta.mjs",
    "indexnow": "node scripts/indexnow.mjs",
    "verify": "oxlint && oxfmt --check && astro check",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.0",
    "@astrojs/rss": "^4.0.18",
    "@astrojs/sitemap": "^3.7.3",
    "@astrojs/svelte": "^9.0.0",
    "@fontsource/shippori-mincho": "^5.2.8",
    "@lucide/svelte": "^1.20.0",
    "@tailwindcss/typography": "^0.5.20",
    "@tailwindcss/vite": "^4.3.1",
    "astro": "^7.0.0",
    "clsx": "^2.1.1",
    "svelte": "^5.56.3",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "lefthook": "^2.1.9",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "png-to-ico": "^3.0.1",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=11.0.0"
  },
  "packageManager": "pnpm@11.7.0"
}
